{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory_bank": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@allpepper/memory-bank-mcp@latest"
      ]
    }
  },
  "plugin": [
    "@dietrichgebert/ponytail",
    "Tarquinen/oc-tps"
  ],
  "lsp": {
    "ruby": {
      "command": [
        "~/.local/share/mise/shims/ruby-lsp"
      ],
      "extensions": [
        ".rb",
        ".erb"
      ]
    }
  }
}
