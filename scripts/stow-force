#!/usr/bin/env bash

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TARGET="${HOME:-~}"

if [ "$#" -eq 0 ]; then
  echo "usage: stow-force <package>..." >&2
  exit 1
fi

if [ -n "$(git -C "$DOTFILES_DIR" status --porcelain -- "$@")" ]; then
  echo "Refusing to stow: uncommitted changes in $* — commit or stash first." >&2
  exit 1
fi

stow --adopt --dir="$DOTFILES_DIR" --target="$TARGET" "$@"
git -C "$DOTFILES_DIR" restore -- "$@"
