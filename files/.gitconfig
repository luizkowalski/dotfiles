[pull]
	rebase = false
[rebase]
    autoStash = true
[core]
  pager = less -F -X
	excludesfile = ~/.gitignore
	; editor = nvim
[include]
	path = ~/.config/dev/gitconfig
[include]
	path = ~/.gitconfig.local
[merge]
    conflictstyle = diff3
[diff]
    external = difft
    colorMoved = default
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[push]
  autoSetupRemote = true
[init]
	defaultBranch = main
[diff "lockb"]
	textconv = bun
	binary = true
[credential]
	helper = osxkeychain
